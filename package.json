{
  "name": "civicmind",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w packages/backend",
    "dev:landing": "npm run dev -w packages/landing-page",
    "dev:citizen": "npm run dev -w packages/citizen-app",
    "dev:authority": "npm run dev -w packages/authority-portal",
    "dev:admin": "npm run dev -w packages/admin-console",
    "dev:frontends": "concurrently \"npm run dev:landing\" \"npm run dev:citizen\" \"npm run dev:authority\" \"npm run dev:admin\"",
    "dev:all": "concurrently \"npm run dev:backend\" \"npm run dev:landing\" \"npm run dev:citizen\" \"npm run dev:authority\" \"npm run dev:admin\"",
    "seed": "npm run seed -w packages/backend",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^10.0.3",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
