# =============================================================================
# CivicMind — Environment Variables Template
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# =============================================================================

# ─────────────────────────────────────────────────────────────────
# Firebase / Google Cloud Project
# ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=civicmind-demo
FIREBASE_STORAGE_BUCKET=civicmind-demo.appspot.com

# Firebase Admin SDK service account key (path to JSON file)
# Download from: Firebase Console → Project Settings → Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json

# ─────────────────────────────────────────────────────────────────
# Backend API
# ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# JWT secret used for internal service tokens (not Firebase tokens)
INTERNAL_SERVICE_SECRET=change-me-in-production

# ─────────────────────────────────────────────────────────────────
# Google Maps Platform
# ─────────────────────────────────────────────────────────────────
# Backend key (server-side geocoding only, restricted to your server IP)
GOOGLE_MAPS_SERVER_API_KEY=your-server-maps-api-key

# Frontend key (map rendering, restricted to your domain/referer)
VITE_GOOGLE_MAPS_CLIENT_API_KEY=your-client-maps-api-key

# ─────────────────────────────────────────────────────────────────
# AI / LLM Provider (Gemini)
# ─────────────────────────────────────────────────────────────────
GOOGLE_GENAI_API_KEY=your-gemini-api-key
GEMINI_MODEL_TEXT=gemini-3.1-flash-lite
GEMINI_MODEL_VISION=gemini-3.1-flash-lite

# ─────────────────────────────────────────────────────────────────
# Demo / Seed Config
# ─────────────────────────────────────────────────────────────────
# City bounding box for the demo deployment (Bengaluru by default)
SERVICE_AREA_LAT_MIN=12.8
SERVICE_AREA_LAT_MAX=13.15
SERVICE_AREA_LNG_MIN=77.4
SERVICE_AREA_LNG_MAX=77.8

# ─────────────────────────────────────────────────────────────────
# Citizen-facing Frontend (Vite)
# ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000
VITE_FIREBASE_API_KEY=your-firebase-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=civicmind-demo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=civicmind-demo
VITE_FIREBASE_STORAGE_BUCKET=civicmind-demo.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Production CORS Origins (required when NODE_ENV=production)
ALLOWED_ORIGINS=https://citizen.civicmind.example.com,https://authority.civicmind.example.com
