{
  "name": "@civicmind/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/scripts/seed/run-seed.ts",
    "seed:departments": "tsx src/scripts/seed/seed-departments.ts",
    "seed:jurisdiction": "tsx src/scripts/seed/seed-jurisdiction.ts",
    "seed:sla": "tsx src/scripts/seed/seed-sla.ts",
    "seed:accounts": "tsx src/scripts/seed/seed-demo-accounts.ts",
    "seed:historical": "tsx src/scripts/seed/seed-historical-issues.ts"
  },
  "dependencies": {
    "@civicmind/shared": "*",
    "@google/genai": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
