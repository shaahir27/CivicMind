rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function getRole() {
      return request.auth.token.role;
    }

    function isCitizen() {
      return isAuthenticated() && getRole() == 'citizen';
    }

    function isAuthority() {
      return isAuthenticated() && getRole() == 'authority';
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isAuthorityOrAdmin() {
      return isAuthority() || isAdmin();
    }

    // ─── Users ──────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Users can read their own profile; admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      // Only the backend (via Admin SDK) writes user records
      allow write: if false;
    }

    // ─── Issues ─────────────────────────────────────────────────────────────

    match /issues/{issueId} {
      // Citizens can read their own issues; authorities/admins read within scope (enforced by backend)
      // Public map view goes through a public endpoint in the backend, not direct Firestore reads
      allow read: if isAuthenticated();
      // All writes go through the backend (orchestrator), never direct client writes
      allow write: if false;
    }

    match /issue_status_history/{historyId} {
      allow read: if isAuthenticated();
      // Append-only — enforced by backend; no client writes
      allow write: if false;
    }

    match /issue_photos/{photoId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    match /corroborations/{corroborationId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ─── Reference / Config data ─────────────────────────────────────────────

    match /departments/{departmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /jurisdiction_mappings/{mappingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sla_config/{configId} {
      allow read: if isAuthorityOrAdmin();
      allow write: if isAdmin();
    }

    match /escalation_tiers/{tierId} {
      allow read: if isAuthorityOrAdmin();
      allow write: if isAdmin();
    }

    // ─── Audit / Logging ─────────────────────────────────────────────────────

    match /agent_decision_log/{logId} {
      // Read-only for admins; writes only via Admin SDK (backend)
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── Notifications ───────────────────────────────────────────────────────

    match /notifications/{notificationId} {
      // Recipients can read their own notifications
      allow read: if isAuthenticated() &&
        request.auth.uid == resource.data.recipient_user_id;
      allow write: if false;
    }

    // ─── Gamification ────────────────────────────────────────────────────────

    match /hero_points_ledger/{ledgerId} {
      allow read: if isAuthenticated() &&
        request.auth.uid == resource.data.user_id;
      allow write: if false;
    }

    // ─── Forecasts & Reports (public reads for some) ─────────────────────────

    match /hotspot_forecasts/{forecastId} {
      // Public-visible forecasts can be read by anyone (is_public_visible filtered by backend)
      allow read: if true;
      allow write: if false;
    }

    match /impact_reports/{reportId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
